					  <a href="javascript:void(0)" class="closebtn" onclick="checkSideTab()">
					  <a href="#">Common Issues</a>
					  <a href="#">Common Code</a>
					  <a href="#">Repository</a>
					  <a href="#">Known Bugs</a>
					</div>				
				<style id="darkStyle">
